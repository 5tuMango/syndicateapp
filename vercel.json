{
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/" }],
  "crons": [
    {
      "path": "/api/create-weekly-multi",
      "schedule": "0 20 * * 0"
    },
    {
      "path": "/api/collect-afl-games",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/collect-afl-stats",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/collect-nrl-games",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/collect-nrl-stats",
      "schedule": "30 15 * * *"
    }
  ],
  "functions": {
    "api/check-results.js": {
      "maxDuration": 300
    },
    "api/check-weekly-results.js": {
      "maxDuration": 300
    },
    "api/match-weekly-multi.js": {
      "maxDuration": 60
    },
    "api/extract-weekly-results.js": {
      "maxDuration": 60
    },
    "api/extract-bet.js": {
      "maxDuration": 60
    },
    "api/extract-results.js": {
      "maxDuration": 60
    }
  }
}
